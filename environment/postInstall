#!/usr/bin/env bash
set -euxo pipefail

# Interactive labeling capsule: install the ROI-quality package (provides the
# `roi-classifier-label` matplotlib GUI). The Ubuntu-desktop base image supplies
# the X display the GUI needs.
cd /
git clone https://github.com/AllenNeuralDynamics/mfish-roi-classifier
cd /mfish-roi-classifier && pip install -e ".[label]"
